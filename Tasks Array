//Check if array is palindrome.
	public static boolean ispalindrome(String arr) {
		int left=0;
		int right=arr.length()-1;
		while(left<right) {
			if(arr.charAt(left)!=arr.charAt(right)) {
				return false;
			}
			left++;
			right--;
			}
		return true;
		}
		

public static void main(String[] args) {
	System.out.println(ispalindrome("rotor"));
	System.out.println(ispalindrome("welcome"));
	
}}	
